# Crawlm — configuration template. Copy to .env and adjust.
# Values below are the polite defaults; missing MONGO_URI / REDIS_URI fail fast.

# ---- HTTP API ----
SERVER_PORT=5000
SERVER_HOST=0.0.0.0
# Prefix every REST route is mounted under.
API_PREFIX=/api/v1
# Allowed browser origin for the web dashboard (packages/web dev server).
CORS_ORIGIN=http://localhost:5173

# ---- MongoDB ----
# Connection string WITHOUT the database name — the db is set via MONGO_DB.
MONGO_URI=mongodb://crawlm:crawlm@mongo:27017
MONGO_DB=crawlm

# ---- Redis (crawl frontier + pub/sub) ----
REDIS_URI=redis://redis:6379

# ---- Auth ----
# MANDATORY: secret used to sign admin JWTs. The API fails fast if unset.
JWT_SECRET=
# Credentials bootstrapped into the single admin account on API startup.
# Leave both empty to skip the admin bootstrap entirely.
ADMIN_EMAIL=admin@crawlm.local
ADMIN_PASSWORD=changeme

# ---- Logging ----
LOG_LEVEL=info
LOG_PRETTY=true

# ---- Crawler tuning (single source of truth) ----
# Concurrent in-flight fetches per worker; total parallelism = this x replicas.
CRAWLER_CONCURRENCY=64
# URLs pulled from the frontier per tick (also the Mongo bulkWrite size).
CRAWLER_BATCH_SIZE=128
# Minimum delay (ms) between two requests to the SAME domain. 0 = no throttle.
CRAWLER_DOMAIN_DELAY_MS=1500
# Max EXTERNAL links harvested from a single page (these grow domain coverage).
CRAWLER_MAX_LINKS_PER_PAGE=40
# Max same-domain (internal) links harvested per page; externals are always kept.
CRAWLER_MAX_INTERNAL_LINKS=5
# Stop chasing a site once this many of its pages are stored (fan out across more
# domains instead of drilling deep). 0 = unlimited.
CRAWLER_MAX_PAGES_PER_DOMAIN=25
# Stop enqueueing once the frontier holds this many pending URLs (back-pressure).
CRAWLER_MAX_FRONTIER=500000
# Hard cap on pages stored before the crawler stops on its own. 0 = unlimited.
CRAWLER_MAX_PAGES=0
# Respect robots.txt directives.
CRAWLER_RESPECT_ROBOTS=true
# Per-request timeout (ms).
CRAWLER_TIMEOUT_MS=15000
# Number of parallel crawler workers (docker compose replicas).
CRAWLER_REPLICAS=3

# ---- External domain sources (run by the `sources` process) ----
# Ingest newly-issued TLS certs from a CertStream-compatible WS feed and seed the
# fresh domains into the frontier. Defaults to the self-hosted certstream service.
SOURCES_CERTSTREAM_ENABLED=true
SOURCES_CERTSTREAM_URL=ws://certstream:8080/full-stream
# Max domains flushed to the frontier per interval, and the flush interval (ms).
SOURCES_MAX_PER_FLUSH=200
SOURCES_FLUSH_MS=2000
